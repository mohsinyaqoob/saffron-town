// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum OrderStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model Order {
  id             String      @id @default(cuid())
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  status         OrderStatus @default(PENDING)
  currency       String      @default("INR")
  subtotalRupees Int
  customerName   String
  phone          String
  email          String
  pincode        String
  heardAboutUs   String?
  cityPin        String?
  notes          String?
  items          OrderItem[]
}

model OrderItem {
  id              String @id @default(cuid())
  orderId         String
  order           Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId       String
  productName     String
  variantId       String
  variantLabel    String
  quantity        Int
  unitPriceRupees Int
  lineTotalRupees Int
}

/// Bulk / wholesale lead from `/bulk-orders`. Persisted before SMTP notify.
model BulkEnquiry {
  id              String    @id @default(cuid())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  name            String    @db.VarChar(120)
  phone           String    @db.VarChar(22)
  email           String?   @db.VarChar(254)
  organization    String?   @db.VarChar(200)
  businessType    String?   @db.VarChar(80)
  approxGrams     String?   @db.VarChar(80)
  timeline        String?   @db.VarChar(120)
  message         String    @db.Text

  clientIp           String?   @db.VarChar(45)
  emailNotifiedAt    DateTime?

  @@index([createdAt])
}
