// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// Order lifecycle: created as PENDING when the customer clicks Pay now,
/// PAID once Razorpay confirms payment, FAILED if payment fails / is
/// dismissed / times out or the order is abandoned.
enum OrderStatus {
  PENDING
  PAID
  FAILED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

/// Whether a courier partner delivers to a given pincode.
/// UNKNOWN = we could not determine it (API error/timeout) and should retry.
enum ServiceabilityStatus {
  SERVICEABLE
  NOT_SERVICEABLE
  UNKNOWN
}

model Order {
  id             String      @id @default(cuid())
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  status         OrderStatus @default(PENDING)
  currency       String      @default("INR")
  subtotalRupees Int
  customerName    String
  phone           String
  email           String
  pincode         String
  /** Full postal address (building, street, area, city, state) as entered at checkout. */
  deliveryAddress String?
  heardAboutUs    String?
  cityPin         String?
  notes           String?
  /** "ONLINE" | "COD" */
  paymentMethod     String   @default("ONLINE")
  razorpayOrderId   String?
  razorpayPaymentId String?
  /** "prebook" | "gifting" | null (regular shop order) */
  source            String?
  items          OrderItem[]

  @@index([source])
}

model Customer {
  id             String    @id @default(cuid())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  name           String    @db.VarChar(120)
  email          String?   @db.VarChar(254)
  phone          String?   @db.VarChar(22)
  companyName    String?   @db.VarChar(160)
  taxId          String?   @db.VarChar(80)
  billingAddress String?   @db.Text
  city           String?   @db.VarChar(100)
  state          String?   @db.VarChar(100)
  postalCode     String?   @db.VarChar(30)
  country        String?   @db.VarChar(100)
  notes          String?   @db.Text
  deletedAt      DateTime?
  invoices       Invoice[]

  @@index([name])
  @@index([email])
  @@index([createdAt])
  @@index([deletedAt])
}

model Invoice {
  id                        String        @id @default(cuid())
  createdAt                 DateTime      @default(now())
  updatedAt                 DateTime      @updatedAt
  invoiceNumber             String        @unique @db.VarChar(64)
  status                    InvoiceStatus @default(DRAFT)
  issueDate                 DateTime
  dueDate                   DateTime?
  currency                  String        @default("INR") @db.VarChar(8)
  customerId                String
  customer                  Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  customerName              String        @db.VarChar(120)
  customerEmail             String?       @db.VarChar(254)
  customerPhone             String?       @db.VarChar(22)
  customerCompanyName       String?       @db.VarChar(160)
  billingAddress            String?       @db.Text
  billingCity               String?       @db.VarChar(100)
  billingState              String?       @db.VarChar(100)
  billingPostalCode         String?       @db.VarChar(30)
  billingCountry            String?       @db.VarChar(100)
  subtotalPaise             Int
  taxTotalPaise             Int           @default(0)
  discountTotalPaise        Int           @default(0)
  totalPaise                Int
  notes                     String?       @db.Text
  paymentTerms              String?       @db.Text
  lineItems                 InvoiceLineItem[]

  @@index([customerId])
  @@index([status, createdAt])
  @@index([issueDate])
  @@index([dueDate])
  @@index([createdAt])
}

model InvoiceLineItem {
  id               String  @id @default(cuid())
  invoiceId        String
  invoice          Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  sortOrder        Int     @default(0)
  description      String  @db.VarChar(300)
  quantity         Int
  unitPricePaise   Int
  taxRatePercent   Int     @default(0)
  discountPaise    Int     @default(0)
  lineSubtotalPaise Int
  lineTaxPaise     Int     @default(0)
  lineTotalPaise   Int

  @@index([invoiceId, sortOrder])
}

model OrderItem {
  id              String @id @default(cuid())
  orderId         String
  order           Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId       String
  productName     String
  variantId       String
  variantLabel    String
  quantity        Int
  unitPriceRupees Int
  lineTotalRupees Int
}

/// Bulk / wholesale lead from `/bulk-orders`. Persisted before SMTP notify.
model BulkEnquiry {
  id              String    @id @default(cuid())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  name            String    @db.VarChar(120)
  phone           String    @db.VarChar(22)
  email           String?   @db.VarChar(254)
  organization    String?   @db.VarChar(200)
  businessType    String?   @db.VarChar(80)
  approxGrams     String?   @db.VarChar(80)
  message         String?   @db.Text

  clientIp           String?   @db.VarChar(45)
  emailNotifiedAt    DateTime?

  @@index([createdAt])
}

/// Courier serviceability cache, keyed by (partner, pincode).
///
/// Serviceability is a property of a pincode, not an order — the same answer
/// applies to every order to that pincode, so we look it up once per partner
/// per pincode and reuse it. Orders join to this by `pincode` at read time.
/// Adding a delivery partner needs an adapter + registry entry only — no
/// change to the Order table. `detail` keeps the raw partner payload (service
/// points, area names) for display and debugging.
model PincodeServiceability {
  id          String               @id @default(cuid())
  partnerCode String               @db.VarChar(60)
  pincode     String               @db.VarChar(12)
  status      ServiceabilityStatus
  detail      Json?
  checkedAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@unique([partnerCode, pincode])
  @@index([pincode])
}
