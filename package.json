{
  "name": "saffron-town",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "studio": "sanity dev",
    "blog-automation": "tsx scripts/blog-automation/run.ts",
    "blog-automation:dry-run": "tsx scripts/blog-automation/run.ts --dry-run",
    "blog-automation:print-one": "tsx scripts/blog-automation/run.ts --print-only --limit 1",
    "blog-automation:sheet-today": "tsx scripts/blog-automation/print-sheet-today.ts",
    "blog-automation:record-url": "tsx scripts/blog-automation/record-published-url.ts",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "build": "prisma generate && next build",
    "dev": "next dev --port 6600",
    "start": "next start --port 6600",
    "lint": "biome check .",
    "lint:autofix": "biome check . --write",
    "gsc:auth": "bash scripts/run-gsc-auth.sh",
    "gsc:reauth": "bash scripts/run-gsc-auth.sh --reauth",
    "docs:bd-playbook": "tsx scripts/generate-bd-playbook-pdf.ts"
  },
  "dependencies": {
    "@google/genai": "^2.0.1",
    "@google/generative-ai": "^0.24.1",
    "@hookform/resolvers": "^5.2.2",
    "@next/third-parties": "^16.2.0",
    "@portabletext/react": "^6.0.3",
    "@portabletext/types": "^4.0.2",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@sanity/client": "^7.18.0",
    "@sanity/icons": "^3.7.4",
    "@sanity/image-url": "^1.2.0",
    "@sanity/vision": "^4.22.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "clsx": "^2.1.1",
    "googleapis": "^171.4.0",
    "gsap": "^3.15.0",
    "next": "16.1.6",
    "next-sanity": "^12.1.3",
    "nodemailer": "^8.0.6",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.72.1",
    "sanity": "^5.24.0",
    "styled-components": "^6.3.12",
    "tailwind-merge": "^2.6.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/pdfkit": "^0.17.6",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^16.6.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "^7.7.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "5.9.3"
  }
}
