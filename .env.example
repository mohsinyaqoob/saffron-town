# Direct Postgres URL required for Prisma Migrate AND for /api/orders (node-pg). Prisma Accelerate (prisma+postgres://) will not work for the orders API.
# Use sslmode=verify-full for TLS (avoids pg@8 deprecation noise; same as sslmode=require today). Local Postgres without TLS: ?sslmode=disable
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/DATABASE?sslmode=verify-full"

# Dashboard at /dashboard — set both before using the internal orders view
DASHBOARD_PASSWORD="Password@123"
# Min 16 chars; used to sign the session cookie (short values are rejected)
DASHBOARD_AUTH_SECRET="replace-with-random-16-plus-chars"

# Optional: dedicated secret for order confirmation + PDF links (defaults to DASHBOARD_AUTH_SECRET or DATABASE_URL server-side)
# ORDER_RECEIPT_SECRET="min-16-chars-random"

# Private new-order alert (shopper is not notified or copied). Sent via Zoho Mail SMTP.
# SMTP_HOST defaults to smtp.zoho.in (use smtp.zoho.com for the .com region, smtp.zoho.eu for EU).
# SMTP_PORT defaults to 465 (implicit TLS); use 587 for STARTTLS.
# SMTP_USER must be a Zoho-hosted mailbox; SMTP_PASSWORD must be a Zoho app password (with 2FA enabled the account password will not work).
# SMTP_HOST="smtp.zoho.in"
# SMTP_PORT="465"
# SMTP_USER="orders@saffron.town"
# SMTP_PASSWORD="zoho-app-password"
# ORDER_NOTIFY_EMAIL="orders@saffron.town"
# Optional sender override; must match the SMTP_USER mailbox or a Zoho-verified alias, otherwise Zoho rejects the message.
# ORDER_NOTIFY_FROM="Saffron Town <orders@saffron.town>"

# Orders API: in-memory rate limit per IP per Vercel isolate (pruned/capped; resets on cold start).

# Sanity CMS (Studio at /studio). Required for live blog content.
# NEXT_PUBLIC_SANITY_PROJECT_ID="your-project-id"
# NEXT_PUBLIC_SANITY_DATASET="production"
# NEXT_PUBLIC_SANITY_API_VERSION="2026-03-19"
# Write token for scripts (e.g. pnpm blog:publish) — create at sanity.io/manage → API → Tokens
# SANITY_API_WRITE_TOKEN=""
